#!/usr/bin/env bash
#
# pre-push — gate every push that updates `main` or a release tag (`v*`) on
# the full quality gate (`pnpm check:all`). Pushes to feature branches are
# NOT gated here — CI gates those through the PR's required `frontend` check.
#
# Why this exists: `main` and `v*` tags can be pushed directly (a local
# `git merge --no-ff` straight to main, or `/bump … and release`), which
# bypasses the PR-based CI gate — the commit is already on the branch by the
# time `on: push` CI runs, so a red gate can't be un-landed. That is exactly
# how the content-server merge (e2a0dffe) reached main red. This hook moves
# the gate to push time, where it actually blocks the bad push.
#
# Bypassing this hook (`git push --no-verify`) is forbidden without explicit
# authorization — see .claude/rules/60-ai-governance.md §9.
#
# Enabled via `git config core.hooksPath .githooks`, set by the root
# package.json `prepare` script (scripts/setup-local-git.mjs) on
# `pnpm install`.
#
# That same setup also adds an SSH keepalive to `core.sshCommand`. This gate
# runs `pnpm check:all` (~3 min) while git holds the SSH connection to the
# remote open; without a keepalive the idle connection times out and the
# subsequent pack upload dies with SIGPIPE (exit 141) — the gate passes but the
# push never lands. If a direct push to `main`/`v*` ever fails that way, run
# `node scripts/setup-local-git.mjs` (or push once with
# `GIT_SSH_COMMAND='ssh -o ServerAliveInterval=20' git push …`).

set -euo pipefail

z40="0000000000000000000000000000000000000000"
gated=0

# git feeds "<local ref> <local sha> <remote ref> <remote sha>" lines on stdin.
while read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "${remote_ref:-}" ] && continue
  [ "$local_sha" = "$z40" ] && continue   # branch/tag deletion — nothing to verify
  case "$remote_ref" in
    refs/heads/main) gated=1 ;;
    refs/tags/v*)    gated=1 ;;
  esac
done

if [ "$gated" -eq 0 ]; then
  exit 0
fi

# Cross-target compile check first: it fails in seconds on the class of
# bug the host-only gate can't see (cfg(target_os) imports/dead-code that
# only break on Windows/Linux — the v0.8.26 release push hit this 4× in a
# row). Soft-skips with a warning if the mingw toolchain isn't installed;
# see scripts/check-cross-target.sh for setup.
echo "pre-push: updating main or a release tag — cross-target compile check…"
if ! bash scripts/check-cross-target.sh; then
  cat >&2 <<'MSG'

✖ pre-push blocked: cross-target compile check failed.
  This code will not compile on Windows CI. Fix before pushing main/v*.
  Overriding (`git push --no-verify`) requires explicit authorization —
  see .claude/rules/60-ai-governance.md §9.
MSG
  exit 1
fi

echo "pre-push: running the full quality gate (pnpm check:all)…"
if ! pnpm check:all; then
  cat >&2 <<'MSG'

✖ pre-push blocked: `pnpm check:all` failed.
  main and release tags must be green before they leave this machine.
  Fix the gate first. Overriding (`git push --no-verify`) requires explicit
  authorization — see .claude/rules/60-ai-governance.md §9.
MSG
  exit 1
fi

echo "✔ pre-push: quality gate green — push allowed."
exit 0
