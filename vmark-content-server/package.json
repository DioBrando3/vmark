{
  "name": "@vmark/content-server",
  "version": "0.8.11",
  "description": "VMark content server — serves a workspace as a cross-linked knowledge base and hosts Slidev. Runs in the bundled Node runtime.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "vmark-content-server": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/smoke.mjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench --run",
    "lint": "eslint src"
  },
  "author": "VMark",
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "@slidev/cli": "^52.16.0",
    "chokidar": "^5.0.0",
    "dompurify": "^3.4.11",
    "hastscript": "^9.0.1",
    "hono": "^4.12.28",
    "ignore": "^7.0.5",
    "jsdom": "^26.1.0",
    "katex": "^0.17.0",
    "mdast-util-find-and-replace": "^3.0.2",
    "playwright-chromium": "^1.61.1",
    "rehype-katex": "^7.0.1",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/katex": "^0.16.8",
    "@types/node": "^22.20.0",
    "@vitest/coverage-v8": "^4.1.10",
    "tsup": "^8.5.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20.12"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
