{
  "name": "@vmark/mcp-server",
  "version": "0.8.28",
  "description": "MCP server for VMark — the plain-text workspace where humans and AI collaborate",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "vmark-mcp-server": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "prepublishOnly": "pnpm build",
    "build:sidecar": "pnpm build && node scripts/build-sidecar.js"
  },
  "keywords": [
    "mcp",
    "vmark",
    "tiptap",
    "editor",
    "ai",
    "claude",
    "codex"
  ],
  "author": "VMark",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.10",
    "@yao-pkg/pkg": "^6.21.0",
    "esbuild": "^0.28.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
